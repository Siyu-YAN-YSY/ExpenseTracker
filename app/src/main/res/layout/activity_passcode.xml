<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@android:color/white"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="56dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgPasscodeLogo"
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:layout_marginBottom="20dp"
        android:contentDescription="@string/app_name"
        android:scaleType="centerCrop"
        android:src="@drawable/logo_wallet"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:strokeColor="@color/blue_primary"
        app:strokeWidth="2dp" />

    <TextView
        android:id="@+id/tvPasscodeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/enter_passcode"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvPasscodeSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/lock_the_app_with_a_4_digit_code"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/layoutDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:orientation="horizontal">

        <View
            android:id="@+id/dot1"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_margin="10dp"
            android:background="@drawable/bg_passcode_dot_empty" />

        <View
            android:id="@+id/dot2"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_margin="10dp"
            android:background="@drawable/bg_passcode_dot_empty" />

        <View
            android:id="@+id/dot3"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_margin="10dp"
            android:background="@drawable/bg_passcode_dot_empty" />

        <View
            android:id="@+id/dot4"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_margin="10dp"
            android:background="@drawable/bg_passcode_dot_empty" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvPasscodeError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text=""
        android:textColor="#D32F2F"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn1"
                style="@style/PasscodeKeyButton"
                android:text="1" />

            <Button
                android:id="@+id/btn2"
                style="@style/PasscodeKeyButton"
                android:text="2" />

            <Button
                android:id="@+id/btn3"
                style="@style/PasscodeKeyButton"
                android:text="3" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn4"
                style="@style/PasscodeKeyButton"
                android:text="4" />

            <Button
                android:id="@+id/btn5"
                style="@style/PasscodeKeyButton"
                android:text="5" />

            <Button
                android:id="@+id/btn6"
                style="@style/PasscodeKeyButton"
                android:text="6" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn7"
                style="@style/PasscodeKeyButton"
                android:text="7" />

            <Button
                android:id="@+id/btn8"
                style="@style/PasscodeKeyButton"
                android:text="8" />

            <Button
                android:id="@+id/btn9"
                style="@style/PasscodeKeyButton"
                android:text="9" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnClear"
                style="@style/PasscodeKeyButtonSecondary"
                android:text="@string/clear"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn0"
                style="@style/PasscodeKeyButton"
                android:text="0" />

            <Button
                android:id="@+id/btnDelete"
                style="@style/PasscodeKeyButtonSecondary"
                android:text="⌫"
                android:textSize="18sp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>